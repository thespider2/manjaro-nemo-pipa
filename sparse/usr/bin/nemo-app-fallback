#!/bin/bash
# Prefer real Glacier binaries; fall back to stock openSUSE apps.
set -euo pipefail
for f in /var/lib/environment/nemo/*.conf; do
  [ -f "$f" ] || continue
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      ''|\#*) continue ;;
      *=*) export "$line" ;;
    esac
  done < "$f"
done
: "${XDG_RUNTIME_DIR:=/run/user/$(id -u)}"
: "${WAYLAND_DISPLAY:=wayland-0}"
export XDG_RUNTIME_DIR WAYLAND_DISPLAY

app="${1:-}"
shift || true
case "$app" in
  browser)
    if command -v glacier-browser >/dev/null 2>&1; then
      exec /usr/bin/nemo-app-launch glacier-browser "$@"
    fi
    exec /usr/bin/nemo-app-launch angelfish "$@"
    ;;
  music)
    if command -v glacier-music >/dev/null 2>&1; then
      exec /usr/bin/nemo-app-launch glacier-music "$@"
    fi
    exec /usr/bin/nemo-app-launch amberol "$@"
    ;;
  camera)
    if command -v glacier-camera >/dev/null 2>&1; then
      exec /usr/bin/nemo-app-launch glacier-camera "$@"
    fi
    exec /usr/bin/nemo-app-launch qcam "$@"
    ;;
  *)
    echo "Usage: nemo-app-fallback {browser|music|camera}" >&2
    exit 1
    ;;
esac
